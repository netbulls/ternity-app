{
  "name": "ternity",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ternity/api db:generate",
    "db:migrate": "pnpm --filter @ternity/api db:migrate",
    "db:seed": "pnpm --filter @ternity/api db:seed",
    "sync:extract": "pnpm --filter @ternity/api sync:extract",
    "sync:transform": "pnpm --filter @ternity/api sync:transform",
    "sync:run": "pnpm --filter @ternity/api sync:run",
    "sync:users": "pnpm --filter @ternity/api sync:users",
    "sync:verify": "pnpm --filter @ternity/api sync:verify"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "//": "Surgical security overrides — each key targets only the vulnerable range and bumps to the minimum patched version within the same major, so no incompatible major is pulled in. Direct deps (fastify, drizzle-orm, vite, react-router-dom) are bumped in their own package.json instead.",
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "flatted@<=3.4.1": "3.4.2",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "undici@<6.27.0": "6.27.0",
      "fast-uri@<=3.1.1": "3.1.2",
      "tmp@<0.2.7": "0.2.7",
      "axios@>=1.0.0 <1.16.0": "1.16.0",
      "form-data@>=4.0.0 <4.0.6": "4.0.6",
      "shell-quote@<1.8.4": "1.8.4",
      "protobufjs@<=7.6.0": "7.6.1",
      "vite@>=6.0.0 <=6.4.2": "6.4.3"
    }
  }
}
